# Copy to .env and fill in real values when ready. Anything left blank runs
# in mock mode (see internal/config/config.go) so the platform still works
# end-to-end without external credentials.

PORT=8080
# Base URL this API is reachable at - used to build URLs for locally-stored
# uploads when CLOUDINARY_* is blank (mock mode).
PUBLIC_API_URL=http://localhost:8080
ENV=development

# Point this at your Neon connection string in prod (sslmode=require).
# Local default targets the docker-compose Postgres on 5433.
DATABASE_URL=postgres://team1:team1@localhost:5433/team1blog?sslmode=disable

JWT_SECRET=dev-insecure-secret-change-me
ACCESS_TOKEN_TTL=24h
REFRESH_TOKEN_TTL=168h
INVITE_TTL=72h

# First origin is used as the base URL for invitation/email deep links.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Resend — leave blank to write emails to backend/.devmail/ instead of sending
RESEND_API_KEY=
RESEND_FROM_ADDR=noreply@team1.blog

# Cloudinary — leave blank to use the local-disk upload fallback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Avalanche / Core wallet payments — leave AVALANCHE_TREASURY_PRIVATE_KEY blank
# to simulate payments instead of sending a real onchain transaction.
# Fuji testnet by default; switch AVALANCHE_RPC_URL to mainnet C-Chain when ready.
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113
AVALANCHE_TREASURY_PRIVATE_KEY=
AVALANCHE_USDC_CONTRACT_ADDRESS=

# Substack — leave blank to use a canned dataset for the Published History tab
SUBSTACK_PUBLICATION_URL=
