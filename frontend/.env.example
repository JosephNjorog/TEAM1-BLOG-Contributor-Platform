# URL of the separate Super Admin app, used to redirect a Super Admin who
# accidentally logs in here back to their own dashboard.
VITE_ADMIN_APP_URL=http://localhost:5174

# Base URL of the API. Leave unset (relative /api/v1) when this app and the
# backend share an origin via reverse proxy. Set to an absolute URL
# (e.g. https://api.example.com/api/v1) when they're on separate domains -
# see frontend/.env.production for this deploy's actual value.
VITE_API_BASE_URL=http://localhost:8080/api/v1
